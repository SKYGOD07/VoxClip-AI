# ===========================
# VoxClip AI Environment Variables
# ===========================

# --- Google Gemini API ---
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Google Cloud Project ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Google Cloud Storage ---
# Create a bucket in GCS Console: https://console.cloud.google.com/storage
GCS_BUCKET_NAME=your-gcs-bucket-name

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/voxclip

# --- OpenAI (Optional Fallback) ---
# Only needed if you want OpenAI as a fallback for transcription/analysis
# AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-key
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Gemini Live API Debug ---
# Set to "true" to enable verbose WebSocket logging
# GEMINI_LIVE_DEBUG=false
